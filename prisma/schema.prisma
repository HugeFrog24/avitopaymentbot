generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  CLIENT
  BOT
}

enum OrderStatus {
  DRAFT
  NEEDS_CLARIFICATION
  CONTEXT_COMPLETE
  WAITING_ADMIN_APPROVAL
  REJECTED
  WAITING_PAYMENT
  PARTIALLY_PAID
  FULLY_PAID
  DELIVERED
  CLOSED
  REFUNDED
}

enum EventActor {
  BOT
  ADMIN
  CLIENT
  SYSTEM
}

// TOPUP / REFUND / ADJUSTMENT → credit (increase balance)
// ORDER_DEBIT                 → debit  (decrease balance)
// amountRub is always stored as a positive magnitude; type encodes direction.
enum WalletTxType {
  TOPUP       // Admin or client adds funds
  ORDER_DEBIT // Wallet funds applied to cover an order payment
  REFUND      // Funds returned to wallet (over-payment or order cancel)
  ADJUSTMENT  // Manual admin correction (positive or negative — use note)
}

// How a PaymentEntry was funded
enum PaymentSource {
  DIRECT // Cash / bank transfer directly earmarked for this order
  WALLET // Deducted from the client's wallet balance
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  role          Role     @default(CLIENT)
  handle        String?  // Telegram @username or chosen display name
  telegramId    String?  @unique
  // Better Auth fields
  name          String?
  email         String?  @unique
  emailVerified Boolean  @default(false)
  image         String?
  isAnonymous   Boolean  @default(false) // true → created via Anonymous plugin (no PII yet)
  isDemo        Boolean  @default(false) // true → demo/showroom account; never real money
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders   Order[]
  wallet   Wallet?
  sessions Session[]
  accounts Account[]
}

// ─── Better Auth — session / account / verification ──────────────────────────

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

// One wallet per CLIENT; ADMIN and BOT users don't need one.
// Created lazily on first top-up (or eagerly on user creation — service layer choice).
// balanceRub is a maintained running total; WalletTransaction is the audit trail.
model Wallet {
  id         String   @id @default(uuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])
  balanceRub Decimal  @default(0) @db.Decimal(12, 2)
  updatedAt  DateTime @updatedAt

  transactions WalletTransaction[]
}

// Every balance movement is recorded here (immutable append-only audit log).
// amountRub is always positive; WalletTxType encodes the direction.
model WalletTransaction {
  id        String       @id @default(uuid())
  walletId  String
  wallet    Wallet       @relation(fields: [walletId], references: [id])

  type      WalletTxType
  amountRub Decimal      @db.Decimal(12, 2)

  // Present for ORDER_DEBIT and REFUND — links back to the order being funded/refunded
  orderId   String?
  order     Order?       @relation(fields: [orderId], references: [id])

  // For ORDER_DEBIT: the PaymentEntry created in parallel (1:1, null for other types)
  paymentEntry PaymentEntry?

  note      String?
  createdAt DateTime     @default(now())

  @@index([walletId])
  @@index([orderId])
}

model Order {
  id               String      @id @default(uuid())
  userId           String
  user             User        @relation(fields: [userId], references: [id])

  // Service details (collected during bot intake)
  serviceName      String?
  tariff           String?
  duration         String?
  originalPrice    Decimal?    @db.Decimal(12, 4)
  originalCurrency String?     // e.g. "USD", "EUR"

  // Balance model — card delivered only when paidRub >= requiredRub
  requiredRub      Decimal     @default(0) @db.Decimal(12, 2)
  paidRub          Decimal     @default(0) @db.Decimal(12, 2)

  // Rate frozen at offer creation time
  rateUsed         Decimal?    @db.Decimal(12, 6)
  rateTimestamp    DateTime?

  // Service fee snapshot — copied from Settings.serviceFeeRub at order creation
  serviceFeeRub    Decimal     @default(500) @db.Decimal(12, 2)

  receiptRequested Boolean     @default(false)  // client requested ФНС receipt (чек)

  status           OrderStatus @default(DRAFT)
  claimToken       String?     @unique  // anonymous access token — share with client

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  payments         PaymentEntry[]
  adjustments      Adjustment[]
  events           OrderEvent[]
  walletTxs        WalletTransaction[]

  @@index([status])
  @@index([userId])
}

// Individual payment confirmations — supports partial payments, wallet debits, top-ups
model PaymentEntry {
  id               String        @id @default(uuid())
  orderId          String
  order            Order         @relation(fields: [orderId], references: [id])

  amountRub        Decimal       @db.Decimal(12, 2)
  source           PaymentSource @default(DIRECT)
  confirmedByAdmin Boolean       @default(false)
  note             String?       // e.g. "top-up after VAT difference"

  // Set when source = WALLET; links to the WalletTransaction that funded this entry (1:1)
  walletTxId       String?       @unique
  walletTx         WalletTransaction? @relation(fields: [walletTxId], references: [id])

  // Optional caller-supplied key; if provided, a second request with the same key is a no-op
  idempotencyKey   String?       @unique

  createdAt        DateTime      @default(now())

  @@index([orderId])
}

// Tracks changes to requiredRub (VAT surprises, rate shifts, etc.)
model Adjustment {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])

  oldRequired Decimal  @db.Decimal(12, 2)
  newRequired Decimal  @db.Decimal(12, 2)
  reason      String   // e.g. "VAT added at checkout", "rate moved +2%"

  createdAt   DateTime @default(now())

  @@index([orderId])
}

// ─── Global config ───────────────────────────────────────────────────────────

// Single-row singleton. Use getSettings() / updateServiceFee() from settingsService.
// Row is bootstrapped with defaults on first read via upsert.
model Settings {
  id            Int      @id @default(1)
  serviceFeeRub Decimal  @default(500) @db.Decimal(12, 2)
  updatedAt     DateTime @updatedAt
}

// Autocomplete suggestions for the "service name" field on the create-order form.
// Not a hard constraint — free text is always accepted. Admin-managed via DB.
model ServiceSuggestion {
  id              String   @id @default(uuid())
  name            String   @unique  // e.g. "Spotify"
  category        String?           // e.g. "Music", "AI Tools", "Video"
  defaultCurrency String?           // pre-fills the currency field, e.g. "USD"
  defaultTariff   String?           // pre-fills the tariff field, e.g. "Premium Individual"
  sortOrder       Int      @default(0) // lower = shown first in results
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([isActive, sortOrder])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin, map: "ServiceSuggestion_name_trgm_gin_idx")
}

// Audit log — every status transition and notable action
model OrderEvent {
  id        String       @id @default(uuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id])

  actor     EventActor
  actorId   String?      // null for BOT / SYSTEM
  actorName String?      // display name snapshot at event time; null for BOT / SYSTEM

  message   String
  oldStatus OrderStatus?
  newStatus OrderStatus?

  createdAt DateTime     @default(now())

  @@index([orderId])
}

// ─── Better Auth — API key plugin ─────────────────────────────────────────────

model Apikey {
  id                  String    @id
  configId            String    @default("default")
  name                String?
  start               String?
  referenceId         String
  prefix              String?
  key                 String
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  enabled             Boolean?  @default(true)
  rateLimitEnabled    Boolean?  @default(true)
  rateLimitTimeWindow Int?      @default(86400000)
  rateLimitMax        Int?      @default(10)
  requestCount        Int?      @default(0)
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime
  updatedAt           DateTime
  permissions         String?
  metadata            String?

  @@index([configId])
  @@index([referenceId])
  @@index([key])
  @@map("apikey")
}
