# ── Database ─────────────────────────────────────────────────────────────────
# Local dev (Postgres on host / exposed port):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/avito_payment"
# Docker Compose — use the service name as the host, not localhost:
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/avito_payment"

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=avito_payment
POSTGRES_PORT=5432

# ── Auth (Better Auth) ────────────────────────────────────────────────────────
# Random secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-in-production"
# Base URL of the app (no trailing slash)
BETTER_AUTH_URL="http://localhost:3000"

# Email address that is allowed to sign in as admin via magic link
ADMIN_EMAIL="admin@example.com"

# ── SMTP (self-hosted) ────────────────────────────────────────────────────────
SMTP_HOST="localhost"
SMTP_PORT="587"
# Set to "true" only for port 465 (SMTPS); leave empty or "false" for STARTTLS
SMTP_SECURE=""
# Leave empty for unauthenticated relay (e.g. local Postfix)
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="no-reply@example.com"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
